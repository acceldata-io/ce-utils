{# ==================================================================== #}
{#  Ambari repo_version body for the ODP stack registered via PUT to      #}
{#  /api/v1/stacks/ODP/versions/<odp_minor_version>/repository_versions/1 #}
{#                                                                        #}
{#  repo_id values here MUST match the <repoid> tags in the VDF XML       #}
{#  (vdf-ODP-part-repository-info.j2). They are Ambari-internal labels    #}
{#  and are independent of the on-mirror directory layout; `utils_version`#}
{#  (currently '1.1.0.22') is a label, not a path segment on the mirror.  #}
{# ==================================================================== #}
{
  "operating_systems":[
    {  
      "OperatingSystems":{  
        "ambari_managed_repositories":false, 
        "os_type":"{{ ambari_config_baseurl_os_family }}"
      }, 
      "repositories":[  
        {  
          "Repositories":{  
            "base_url":"{{ ambari_config_odp_main_repo_url }}", 
            "repo_id":"ODP-{{ odp_minor_version }}",
            "repo_name":"ODP" 
          } 
        },
        {  
          "Repositories":{  
            "base_url":"{{ ambari_config_utils_repo_url }}", 
            "repo_id":"ODP-UTILS-{{ utils_version }}", 
            "repo_name":"ODP-UTILS" 
          } 
        },
        {  
          "Repositories":{  
            "base_url":"{{ ambari_config_gpl_repo_url }}", 
            "repo_id":"ODP-{{ odp_minor_version }}-GPL",
            "repo_name":"ODP-GPL" 
          } 
        }
      ]
    }
  ] 
}
